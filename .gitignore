# scripts/deploy.sh rewrites k8s/kustomization.yaml with account-specific
# values. After cloning, run `git update-index --assume-unchanged k8s/kustomization.yaml`
# locally so post-deploy edits don't show up in git status. (Not gitignored
# globally because the template needs to exist in the repo for fresh clones.)

